{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polymath.local/schemas/native_kernel_telemetry.json",
  "title": "Polymath Native Kernel Telemetry",
  "type": "object",
  "required": ["schema_version", "run_id", "target", "backend", "status", "cases"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "run_id": {"type": "string"},
    "timestamp_utc": {"type": "string"},
    "target": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {"type": "string", "enum": ["mac_host", "redmagic_adb", "runpod", "rampard"]},
        "device_model": {"type": "string"},
        "soc_model": {"type": "string"},
        "os": {"type": "string"}
      },
      "additionalProperties": true
    },
    "backend": {"type": "string", "enum": ["cpu", "opencl", "vulkan", "npu", "unknown"]},
    "status": {"type": "string", "enum": ["pass", "fail", "error", "deferred"]},
    "battery": {
      "type": "object",
      "properties": {
        "level_percent": {"type": "number"},
        "temperature_c": {"type": "number"},
        "status": {"type": "string"}
      },
      "additionalProperties": true
    },
    "thermal": {
      "type": "object",
      "properties": {
        "status": {"type": "string"},
        "raw": {"type": "string"}
      },
      "additionalProperties": true
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": {"type": "string"},
          "status": {"type": "string", "enum": ["pass", "fail", "error", "skipped"]},
          "latency_ms": {"type": "number"},
          "max_abs_error": {"type": "number"},
          "max_rel_error": {"type": "number"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
